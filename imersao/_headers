/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://connect.facebook.net https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; frame-src https://www.youtube-nocookie.com https://www.youtube.com; connect-src 'self' https://*.facebook.com https://*.clarity.ms https://c.bing.com; base-uri 'self'; frame-ancestors 'none'

# Cache longo para assets estáticos (imagens e fontes)
/img/*
  Cache-Control: public, max-age=31536000, immutable
/imersao/img/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML sempre revalidado
/*.html
  Cache-Control: public, max-age=0, must-revalidate
